{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "isolatedModules": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "types": ["svelte", "vite/client"]
  },
  "include": [
    "src/renderer/**/*.ts",
    "src/renderer/**/*.svelte",
    "src/shared/**/*.ts"
  ]
}

